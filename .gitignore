# macOS
.DS_Store

# Environment files
.env
.env.*
!.env.example
.platform-state/

# Handoffs (working copies — all runtime; canonical sources in templates/)
AgentWorkSpace/handoffs/*
!AgentWorkSpace/handoffs/.gitkeep

# Canonical templates (all tracked; read-only by convention)
!AgentWorkSpace/templates/

# Task implementation steps (runtime slices — all ignored)
AgentWorkSpace/ImplementationSteps/*
!AgentWorkSpace/ImplementationSteps/.gitkeep

# QMD long-term memory archive (runtime — all ignored)
AgentWorkSpace/qmd/*
!AgentWorkSpace/qmd/.gitkeep

# Queue-based task intake
AgentWorkSpace/dropbox/*
!AgentWorkSpace/dropbox/.gitkeep
!AgentWorkSpace/dropbox/.staging
AgentWorkSpace/dropbox/.staging/*
!AgentWorkSpace/dropbox/.staging/.gitkeep
AgentWorkSpace/pendingitems/*
!AgentWorkSpace/pendingitems/.gitkeep
AgentWorkSpace/erroritems/*
!AgentWorkSpace/erroritems/.gitkeep

# Context packs (per-user local state)
contextpacks/*
!contextpacks/.gitkeep

# Scratch workspace
scratchspace/*
!scratchspace/README.md

# Python
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.nox/
.tox/
.pyre/
.eggs/
*.egg-info/
pip-wheel-metadata/
.coverage
coverage/
htmlcov/
.ipynb_checkpoints/

# Node / frontend
node_modules/
dist/
dist-electron/
build/
.next/
.vite/
release/
*.tsbuildinfo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.out
*.err
*.pid

# Editors
.vscode/settings.json
.vscode/tasks.json
.vscode/launch.json
.idea/

# OS / temp
*.tmp
*.swp
.cache/
tmp/
temp/
CLAUDE.md
.github/copilot-instructions.md

# Validation local overrides
packages/validation/data/file-size-pmseline.txt
