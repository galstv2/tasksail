{
  "name": "@tasksail/custom-terminal-ui",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Electron desktop shell for the TaskSail operator UI.",
  "author": "TaskSail",
  "productName": "TaskSail",
  "main": "dist-electron/main.js",
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "scripts": {
    "predev": "cd ../../.. && npx tsx src/backend/platform/container/cli.ts bootstrap",
    "dev": "vite",
    "build": "vite build",
    "clean": "node -e \"['dist','dist-electron','node_modules/.vite'].forEach(p=>require('fs').rmSync(p,{recursive:true,force:true}))\"",
    "validate:desktop": "npm run test:css-colors && npm test && npm run lint && npm run build",
    "package:mac": "npm run build && electron-builder --mac dir",
    "package:mac:zip": "npm run build && electron-builder --mac zip",
    "package:win": "npm run build && electron-builder --win nsis",
    "package:linux": "npm run build && electron-builder --linux AppImage deb",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:css-colors": "vitest run src/renderer/styles/__tests__/cssColorTokenDiscipline.test.ts -t \"production renderer CSS has zero color literals outside variables.css\" --reporter=dot",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.tasksail.desktop",
    "directories": {
      "output": "release"
    },
    "icon": "build/icon.png",
    "files": [
      "dist/**",
      "dist-electron/**",
      "build/icon.png",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../../LICENSE",
        "to": "LICENSE"
      },
      {
        "from": "../../../THIRD_PARTY_LICENSES.md",
        "to": "THIRD_PARTY_LICENSES.md"
      },
      {
        "from": "src/assets/fonts/OFL-Outfit.txt",
        "to": "licenses/OFL-Outfit.txt"
      },
      {
        "from": "src/assets/fonts/OFL-SourceCodePro.txt",
        "to": "licenses/OFL-SourceCodePro.txt"
      },
      {
        "from": "src/assets/fonts/README.md",
        "to": "licenses/fonts-README.md"
      }
    ],
    "asarUnpack": [
      "dist-electron/pipelineChildEntry.js"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dir",
        "zip"
      ],
      "artifactName": "tasksail-${version}-${arch}.${ext}"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "tasksail-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "artifactName": "tasksail-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.8",
    "electron": "^41.2.1",
    "electron-builder": "^26.15.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.8.2",
    "vite": "^6.4.2",
    "vite-plugin-electron": "^0.29.0",
    "vitest": "^4.1.8"
  }
}
