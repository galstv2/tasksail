# Full reference for every supported variable (incl. ones not listed here):
# docs/reference/environment-variables.md

# General
PROJECT_NAME=tasksail
APP_ENV=development

# Active context-pack container-side POSIX path (resolved by bootstrap; set via Electron UI or manually)
ACTIVE_CONTEXT_PACK_DIR=

# ACTIVE_CONTEXT_PACK_HOST_DIR (normally unset; populated automatically by the
# bootstrap layer for out-of-tree context packs). Operators do not normally
# set this by hand. See docs/cross-os-setup.md.
# ACTIVE_CONTEXT_PACK_HOST_DIR=

# --- Repo Context MCP ---
REPO_CONTEXT_MCP_URL=http://localhost:8811/sse
REPO_CONTEXT_MCP_HOST=127.0.0.1
REPO_CONTEXT_MCP_AUTH_TOKEN=replace-with-local-secret
# REPO_CONTEXT_MCP_PORT=8811
# REPO_CONTEXT_MCP_AUTH_HEADER=X-Repo-Context-Token
# REPO_CONTEXT_MCP_MAX_REQUEST_BYTES=65536
# REPO_CONTEXT_MCP_SOCKET_TIMEOUT=30

# Writable repo-context data mount used by Docker Compose. When the active
# context pack lives outside this repository, point both variables at that
# external directory and prefer the same absolute path for host and container
# so host-originated absolute paths still resolve inside the container.
REPO_CONTEXT_MCP_CONTEXT_DATA_HOST_DIR=../../../AgentWorkSpace/qmd
REPO_CONTEXT_MCP_CONTEXT_DATA_CONTAINER_DIR=/data/qmd

# --- QMD configuration ---
# Relative to the active context pack unless absolute
CONTEXT_PACK_QMD_REPO_SOURCES_FILE=qmd/repo-sources.json
CONTEXT_PACK_QMD_DRY_RUN_PLAN_FILE=qmd/bootstrap/seed-plan.json
# QMD_GLOBAL_RETROSPECTIVE_ROOT=qmd/global/retrospectives
# QMD_MAX_FILES_PER_REPO=200

# --- Container runtime ---
# The active container runtime is controlled by .platform-state/platform.json
# (container_runtime). Use CONTAINER_RUNTIME only as a temporary session override.
# Set container_engine_host there for Docker Desktop, Podman Desktop, or named WSL engine topology.
# CONTAINER_RUNTIME=docker|podman|direct

# --- Enterprise mirrors / internal registries (optional) ---
# For air-gapped or firewalled setups that proxy npm/PyPI/base images through an
# internal mirror (e.g. JFrog Artifactory). All optional; unset = public defaults.
# Package managers do NOT read this file during the very first install. Before the
# first `pnpm install` / `npm ci` / `pip install`, export the package-manager-native
# vars in your shell (see docs/cross-os-setup.md):
#   NPM_CONFIG_REGISTRY, NPM_CONFIG_REPLACE_REGISTRY_HOST=npmjs, PIP_INDEX_URL
# After .env exists, `pnpm run setup` reads the TASKSAIL_* aliases below.
# TASKSAIL_NPM_REGISTRY=https://artifactory.example.internal/api/npm/npm-virtual/
# TASKSAIL_NPM_AUTH_TOKEN=        (export in your shell or inject from a secret store; never commit a real token)
# TASKSAIL_PYPI_INDEX_URL=https://artifactory.example.internal/api/pypi/pypi-virtual/simple/
# Docker/Podman base-image overrides (private base-image auth stays docker/podman login):
# TASKSAIL_PYTHON_BASE_IMAGE=registry.example.internal/python:3.12-alpine
# TASKSAIL_ALPINE_BASE_IMAGE=registry.example.internal/alpine:3.20

# Logging
LOG_LEVEL=info

# Windows operators: task activation can use ReFS Copy-on-Write if
# the repo lives on a Dev Drive or other ReFS volume AND the optional
# native package @reflink/reflink installed successfully. No env vars
# control this — the platform auto-detects. See docs/cross-os-setup.md.
